let A = [1, 2; 3, 4];
let x = A[0];
x[1] := 10;
\print(A);

A[1][0] := 30;
\print(A);

let B = [1, 2, 3; 4, 5, 6; 7, 8, 9];
let S = B[0..2][1..3];
\print(S);
S[0..2][0..2] := 99;
\print(B);

let C = [1, 2; 3, 4];
let D = \copy(C);
D[0][0] := 99;
\print(C);
\print(D);

let r_vec = [1, 2, 3, 4];
let c_vec = \copy(r_vec, 1..3);
\print(c_vec);

let a = 10;
let r = \ref(a);
r := 20;
\print(a);

let v = [10, 20, 30];
for row in \as_mat(v) {
  \print(row);
}
for elem in v {
  \print(elem);
}
