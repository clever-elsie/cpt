let x = if (1 < 2) { 10 } else { 20 };
\print(x)

let y = if (1 > 2) 30 else 40;
\print(y)

let i = 0;
let sum = 0;
while (i < 5) {
  sum := sum + i;
  i := i + 1;
};
\print(sum)

let fsum = 0;
for j in 1..=5 {
  fsum := fsum + j;
};
\print(fsum)

let fsum2 = 0;
for j in 1..5 {
  fsum2 := fsum2 + j;
};
\print(fsum2)

let double = (a) { a * 2 };
\print(double(5))

let filtered = 1..=10 | \filter((n) { n % 2 == 0 }) | \transform((n) { n * 10 });
filtered
